import os, json, base64, requests
import numpy as np
import cv2
from PIL import Image
import pandas as pd
import matplotlib.pyplot as plt
import easyocr

reader = easyocr.Reader(['en','hi'], gpu=False)

HF_API_KEY = os.environ.get("HF_API_KEY")
FEATHERLESS_API_KEY = os.environ.get("FEATHERLESS_API_KEY")

PRIVACY_MODE = True

print("✅ System Ready (Stable + Ensemble)")

# %%
def preprocess_image(img_bytes):
    arr = np.frombuffer(img_bytes, np.uint8)
    img = cv2.imdecode(arr, cv2.IMREAD_COLOR)

    lab = cv2.cvtColor(img, cv2.COLOR_BGR2LAB)
    l,a,b = cv2.split(lab)

    clahe = cv2.createCLAHE(clipLimit=2.0)
    l = clahe.apply(l)

    enhanced = cv2.cvtColor(cv2.merge([l,a,b]), cv2.COLOR_LAB2BGR)

    return Image.fromarray(cv2.cvtColor(enhanced, cv2.COLOR_BGR2RGB))

# %%
def extract_text_blocks(image):
    results = reader.readtext(np.array(image), detail=1)

    blocks = []

    for (bbox, text, conf) in results:
        x = [p[0] for p in bbox]
        y = [p[1] for p in bbox]

        blocks.append({
            "text": text,
            "confidence": float(conf),
            "bbox": (int(min(x)), int(min(y)), int(max(x)), int(max(y)))
        })

    return blocks

# %%
def format_blocks_for_prompt(blocks):
    return "\n".join([
        f"Text: {b['text']} | Box: {b['bbox']} | Conf: {b['confidence']}"
        for b in blocks
    ])

# %%
def mistral_extract(image, blocks_text):
    if not FEATHERLESS_API_KEY:
        return None

    _, buffer = cv2.imencode('.jpg', np.array(image))
    img_base64 = base64.b64encode(buffer).decode()

    prompt = f"""
    Extract structured fields from this form.

    OCR blocks:
    {blocks_text}

    Return JSON list:
    field_name, value, is_handwritten, confidence
    """

    payload = {
        "model": "mistral-large-latest",
        "messages": [{
            "role": "user",
            "content": [
                {"type":"text","text":prompt},
                {"type":"image_url","image_url":{"url":f"data:image/jpeg;base64,{img_base64}"}}
            ]
        }]
    }

    headers = {
        "Authorization": f"Bearer {FEATHERLESS_API_KEY}",
        "Content-Type": "application/json"
    }

    res = requests.post("https://api.featherless.ai/v1/chat/completions",
                        headers=headers, json=payload)

    try:
        return res.json()["choices"][0]["message"]["content"]
    except:
        return None

# %%
def internvl_extract(blocks_text):
    if not HF_API_KEY:
        return None

    url = "https://api-inference.huggingface.co/models/Qwen/Qwen2-7B-Instruct"
    headers = {"Authorization": f"Bearer {HF_API_KEY}"}

    prompt = f"""
    Extract structured form data from:

    {blocks_text}

    Return JSON list of fields.
    """

    res = requests.post(url, headers=headers, json={"inputs": prompt})

    return res.json()

# %%
def safe_parse_llm_output(output):
    if output is None:
        return []

    if isinstance(output, list):
        return output

    if isinstance(output, str):
        try:
            return json.loads(output)
        except:
            return []

    if isinstance(output, dict):
        if "generated_text" in output:
            try:
                return json.loads(output["generated_text"])
            except:
                return []

    return []

# %%
def merge_outputs(out1, out2):
    if not out1:
        return out2
    if not out2:
        return out1

    merged = []

    for f1 in out1:
        if not isinstance(f1, dict):
            continue

        best = f1

        for f2 in out2:
            if not isinstance(f2, dict):
                continue

            if f1.get("field_name","").lower() == f2.get("field_name","").lower():
                best["confidence"] = (
                    f1.get("confidence",0.5) +
                    f2.get("confidence",0.5)
                ) / 2
                break

        merged.append(best)

    return merged

# %%
def calibrate_confidence(fields):
    safe_fields = []

    for f in fields:
        if not isinstance(f, dict):
            continue

        val = str(f.get("value",""))

        conf = f.get("confidence", 0.5)

        if len(val.strip()) == 0:
            conf *= 0.5

        if any(c.isdigit() for c in val):
            conf += 0.05

        f["confidence"] = min(1.0, conf)

        safe_fields.append(f)

    return safe_fields

# %%
def mask_data(data):
    masked = {}

    for k,v in data.items():
        val = str(v)

        if "aadhaar" in k.lower():
            masked[k] = "XXXX XXXX " + val[-4:]
        elif "pan" in k.lower():
            masked[k] = val[:2] + "XXXXX" + val[-2:]
        else:
            masked[k] = val

    return masked

# %%
def extract_document(image):
    blocks = extract_text_blocks(image)
    blocks_text = format_blocks_for_prompt(blocks)

    out1 = safe_parse_llm_output(mistral_extract(image, blocks_text))
    out2 = safe_parse_llm_output(internvl_extract(blocks_text))

    merged = merge_outputs(out1, out2)

    if not isinstance(merged, list):
        merged = []

    final = calibrate_confidence(merged)

    return {
        "blocks": blocks,
        "fields": final
    }

# %%
def display_table(fields):
    rows = []

    for f in fields:
        rows.append([
            f.get("field_name",""),
            f.get("value",""),
            "handwritten" if f.get("is_handwritten") else "printed",
            round(f.get("confidence",0),2)
        ])

    df = pd.DataFrame(rows, columns=["Field","Value","Type","Confidence"])
    display(df)

# %%
def draw_boxes(image, blocks):
    img = np.array(image.copy())

    for b in blocks:
        x1,y1,x2,y2 = b["bbox"]
        cv2.rectangle(img,(x1,y1),(x2,y2),(0,255,0),2)

    return Image.fromarray(img)

# %%
from google.colab import files

def auto_rotate(image):
    """
    Try 4 orientations and pick best OCR confidence
    """
    rotations = [
        image,
        image.rotate(90, expand=True),
        image.rotate(180, expand=True),
        image.rotate(270, expand=True)
    ]

    best_img = image
    best_score = 0

    for img in rotations:
        blocks = extract_text_blocks(img)
        score = sum([b["confidence"] for b in blocks])

        if score > best_score:
            best_score = score
            best_img = img

    return best_img


ALL_RESULTS = []

uploaded = files.upload()

for fname in uploaded:
    print(f"\n📄 Processing: {fname}")

    raw_img = preprocess_image(uploaded[fname])
    image = auto_rotate(raw_img)

    result = extract_document(image)

    print("\n📊 Extracted Data (UNMASKED):")
    display_table(result["fields"])

    # Build structured data
    data = {
        f.get("field_name",""): f.get("value","")
        for f in result["fields"]
    }

    print("\n🧹 Cleaned Data:")
    cleaned = {k: " ".join(v.split()).title() for k,v in data.items()}
    for k,v in cleaned.items():
        print(f"{k}: {v}")

    print("\n🖼️ Visual:")
    plt.imshow(draw_boxes(image, result["blocks"]))
    plt.axis("off")
    plt.show()

    ALL_RESULTS.append({
        "image": image,
        "blocks": result["blocks"],
        "data": cleaned
    })

print("\n✅ All images processed. Ready for audit.")

# %%
def crop_region(image, coords):
    x1,y1,x2,y2 = coords
    return image.crop((x1,y1,x2,y2))


def extract_from_region(image):
    blocks = extract_text_blocks(image)
    return " ".join([b["text"] for b in blocks])


def mask_toggle(data, mask=True):
    if not mask:
        return data

    masked = {}
    for k,v in data.items():
        if "aadhaar" in k.lower():
            masked[k] = "XXXX XXXX " + v[-4:]
        elif "pan" in k.lower():
            masked[k] = v[:2] + "XXXXX" + v[-2:]
        else:
            masked[k] = v
    return masked


FINAL_DATA = []

for idx, item in enumerate(ALL_RESULTS):
    print(f"\n🧾 AUDITING IMAGE {idx+1}")

    image = item["image"]
    data = item["data"].copy()

    while True:
        print("\nOptions:")
        print("1 → Correct existing field")
        print("2 → Add missing field (select region)")
        print("3 → Done")

        choice = input("Select option: ")

        if choice == "1":
            key = input("Field name: ")
            val = input("New value: ")

            data[key] = val
            print("✅ Updated")

        elif choice == "2":
            print("Enter coordinates: x1,y1,x2,y2")
            coords = input("Coords: ")

            try:
                x1,y1,x2,y2 = map(int, coords.split(","))
                region = crop_region(image, (x1,y1,x2,y2))

                text = extract_from_region(region)

                print(f"🔍 Extracted: {text}")

                field_name = input("Assign field name: ")
                data[field_name] = text

            except:
                print("⚠️ Invalid input")

        elif choice == "3":
            break

    FINAL_DATA.append(data)


# 🔓 MASK TOGGLE
print("\n🔐 Choose output mode:")
mode = input("Type 'mask' or 'unmask': ").lower()

for i, data in enumerate(FINAL_DATA):
    print(f"\n📊 FINAL DATA (Image {i+1}):")

    output = mask_toggle(data, mask=(mode=="mask"))

    for k,v in output.items():
        print(f"{k}: {v}")